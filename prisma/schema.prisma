generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============ IDENTITY & WORKSPACE ============

model User {
  id             String               @id @default(uuid())
  email          String               @unique
  passwordHash   String               @map("password_hash")
  name           String?
  isSuperAdmin   Boolean              @default(false) @map("is_super_admin")
  createdAt      DateTime             @default(now()) @map("created_at")
  memberships    WorkspaceMember[]
  passwordResets PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("password_reset_tokens")
}

model Workspace {
  id                           String    @id @default(uuid())
  name                         String
  slug                         String    @unique
  plan                         String    @default("free") // 'free' | 'starter' | 'pro' | 'enterprise'
  isActive                     Boolean   @default(true) @map("is_active")
  website                      String?
  phone                        String?
  timezone                     String    @default("America/New_York")
  logoUrl                      String?   @map("logo_url")
  senderName                   String?   @map("sender_name") // from name for emails
  senderEmail                  String?   @map("sender_email") // reply-to for emails
  senderVerifiedId             String?   @map("sender_verified_id") // legacy: SendGrid single-sender id
  senderVerifiedAt             DateTime? @map("sender_verified_at") // legacy
  senderAddress                Json?     @map("sender_address") // { line1, line2, city, state, zip, country }
  senderDomain                 String?   @map("sender_domain") // e.g. "spotless.homes"
  senderDomainId               String?   @map("sender_domain_id") // SendGrid whitelabel domain id
  senderDomainValidatedAt      DateTime? @map("sender_domain_validated_at")
  settings                     Json? // extensible provider config: { indeed: {...}, calendly: {...} }
  // Meet integration v2 feature flag — gates the new in-app Google Meet scheduling
  // flow. Off by default so the existing Calendly/Calendar path stays intact.
  meetIntegrationV2Enabled     Boolean   @default(false) @map("meet_integration_v2_enabled")
  // Pipeline Transitions v2 — workspace-level opt-in for the rule-driven
  // pipeline engine. Even when the global env flag PIPELINE_TRANSITIONS_V2 is
  // on, a pipeline only uses the V2 path when BOTH this flag (or the per-
  // pipeline flag below) AND the env flag are true. Off by default so
  // workspaces relying on legacy fallback / completion-pair auto-advance
  // (e.g. Dispatcher pipelines with zero stage triggers) keep their current
  // behavior until the recruiter opts in.
  pipelineTransitionsV2Enabled Boolean   @default(false) @map("pipeline_transitions_v2_enabled")
  // Recall.ai bot integration — when on, every booked InterviewMeeting gets a
  // recording bot scheduled at scheduledStart-1m. The bot replaces the Meet
  // native auto-record path (which silently auto-stops when the host is alone)
  // and supplies its own attendance signal. Off by default; enabled per
  // workspace via /api/integrations/recall/connect once RECALL_API_KEY is set
  // in env.
  recallBotEnabled             Boolean   @default(false) @map("recall_bot_enabled")
  // Unified stale-detection threshold. Applies to all pipelines / stages by
  // default. The cron flips an `active` candidate to `stalled` when
  // `Session.lastProgressAt` (real forward-progress events only) is older than
  // this many days. Null falls back to STALE_DETECTION_DEFAULT_DAYS in
  // src/lib/candidate-status.ts. Per-pipeline / per-stage overrides are a
  // future feature; this column is the only knob exposed in the UI today.
  defaultStalledDays           Int?      @map("default_stalled_days")
  // ---- Stripe Billing (per-workspace subscription) ----
  // Stripe is the source of truth; these mirror state via webhooks so we can
  // gate features without a Stripe round-trip. `plan` (above) is set from the
  // active price ID at webhook time. `subscriptionStatus` follows Stripe's
  // enum: trialing | active | past_due | canceled | incomplete | incomplete_expired | unpaid | paused.
  stripeCustomerId             String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId         String?   @unique @map("stripe_subscription_id")
  stripePriceId                String?   @map("stripe_price_id")
  subscriptionStatus           String?   @map("subscription_status")
  currentPeriodEnd             DateTime? @map("current_period_end")
  cancelAtPeriodEnd            Boolean   @default(false) @map("cancel_at_period_end")
  trialEndsAt                  DateTime? @map("trial_ends_at")
  createdAt                    DateTime  @default(now()) @map("created_at")
  updatedAt                    DateTime  @updatedAt @map("updated_at")

  members           WorkspaceMember[]
  videos            Video[]
  pictures          Picture[]
  flows             Flow[]
  ads               Ad[]
  sessions          Session[]
  trainings         Training[]
  emailTemplates    EmailTemplate[]
  smsTemplates      SmsTemplate[]
  automationRules   AutomationRule[]
  automationEvents  AutomationEvent[]
  schedulingConfigs SchedulingConfig[]
  adTemplates       AdTemplate[]
  aiCallConfigs     AICallConfig[]
  aiCallCandidates  AICallCandidate[]
  googleIntegration GoogleIntegration?
  interviewMeetings InterviewMeeting[]
  certnIntegration  CertnIntegration?
  backgroundChecks  BackgroundCheck[]
  captureResponses  CaptureResponse[]
  pipelines         Pipeline[]
  transitionRules   PipelineTransitionRule[]
  stageEntries      StageEntry[]
  billingEvents     BillingEvent[]
  candidateEvaluations CandidateEvaluation[]
  hiringProcesses   HiringProcess[]

  @@map("workspaces")
}

// Audit log of every Stripe webhook event we process. Lets us debug
// "why is my workspace stuck on past_due" and replay if needed. Dedup'd by
// Stripe event id (unique) so retries can't double-apply.
model BillingEvent {
  id            String     @id @default(uuid())
  workspaceId   String?    @map("workspace_id")
  workspace     Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  stripeEventId String     @unique @map("stripe_event_id")
  type          String // e.g. customer.subscription.updated
  payload       Json // raw event for forensic replay
  processedAt   DateTime   @default(now()) @map("processed_at")

  @@index([workspaceId, processedAt])
  @@map("billing_events")
}

// A named funnel stage list. Each workspace can have many pipelines so roles
// with different hiring loops (e.g. Cleaner with onboarding training vs.
// Dispatcher without) can use distinct kanban columns and stage triggers.
//
// Stages live in the JSON payload — same shape as the legacy
// Workspace.settings.funnelStages array (id, label, tone, color, order,
// triggers[]). Validated through normalizeStages() in src/lib/funnel-stages.ts
// on every read so a corrupt JSON blob falls back to DEFAULT_FUNNEL_STAGES
// rather than crashing the kanban.
//
// Each workspace has exactly one `isDefault: true` pipeline (enforced at the
// app layer in src/lib/pipelines.ts). The default acts as the fallback for
// flows with `pipelineId = null` and is the one new flows are wired to.
model Pipeline {
  id                   String    @id @default(uuid())
  workspaceId          String    @map("workspace_id")
  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name                 String
  // Validated by normalizeStages(). Stored as JSON for the same reason
  // funnelStages did: stages are user-editable and the migration cost of
  // turning each property into a column doesn't pay off.
  stages               Json
  isDefault            Boolean   @default(false) @map("is_default")
  // Pipeline Transitions v2 — per-pipeline opt-in. Same semantics as
  // Workspace.pipelineTransitionsV2Enabled but scoped to one pipeline so a
  // workspace can migrate role-by-role (Cleaner first, Dispatcher later). The
  // engine uses V2 when (env flag is true) AND (this flag OR the workspace
  // flag is true). Off by default; pipelines with no PipelineTransitionRule
  // rows MUST NOT have this turned on, otherwise candidates get stuck.
  transitionsV2Enabled Boolean   @default(false) @map("transitions_v2_enabled")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  flows           Flow[]
  automationRules AutomationRule[]
  transitionRules PipelineTransitionRule[]
  stageEntries    StageEntry[]
  hiringProcesses HiringProcess[]

  @@index([workspaceId])
  @@index([workspaceId, isDefault])
  @@map("pipelines")
}

// A "Hiring Process" is the reusable, top-level recruiting journey for a role
// (e.g. "Residential Cleaner"). It is purely an orchestration layer — it does
// NOT own any new builders. Instead it points at existing primitives:
//
//   - Flow              (the application form)
//   - Training          (optional onboarding course)
//   - SchedulingConfig  (optional interview booker)
//   - Pipeline          (the kanban stage list candidates flow through)
//   - AutomationRule[]  (the default rules wired up for this role)
//
// Lifecycle: a process is created as `draft`. A draft cannot accept candidates
// — the candidate-attach path on /f/:slug only matches rows with
// status='active'. Activating requires both flowId AND pipelineId to be set
// (enforced at the API). `archived` is the soft-retire state: existing
// candidates keep their processId, but new sessions stop attaching.
//
// Uniqueness: at most one ACTIVE process per (workspaceId, flowId). This is
// what makes the "find by flowId" lookup at session-create unambiguous.
// Enforced via partial unique index, defined inline below.
model HiringProcess {
  id                 String                    @id @default(uuid())
  workspaceId        String                    @map("workspace_id")
  workspace          Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name               String
  description        String?
  // 'draft' | 'active' | 'archived'. New rows start as 'draft'. Validation
  // for 'active' lives at the API layer (requires flowId + pipelineId).
  status             String                    @default("draft")
  // All four references are nullable on purpose: drafts can be saved with
  // partial wiring, then completed later. onDelete: SetNull so deleting the
  // underlying flow/training/etc. doesn't cascade-destroy the process — the
  // recruiter just sees an empty slot and re-picks.
  flowId             String?                   @map("flow_id")
  flow               Flow?                     @relation(fields: [flowId], references: [id], onDelete: SetNull)
  trainingId         String?                   @map("training_id")
  training           Training?                 @relation(fields: [trainingId], references: [id], onDelete: SetNull)
  schedulingConfigId String?                   @map("scheduling_config_id")
  schedulingConfig   SchedulingConfig?         @relation(fields: [schedulingConfigId], references: [id], onDelete: SetNull)
  pipelineId         String?                   @map("pipeline_id")
  pipeline           Pipeline?                 @relation(fields: [pipelineId], references: [id], onDelete: SetNull)
  createdAt          DateTime                  @default(now()) @map("created_at")
  updatedAt          DateTime                  @updatedAt @map("updated_at")

  automations HiringProcessAutomation[]
  sessions    Session[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  // Partial unique on active-per-flow is what we'd want long-term, but
  // Prisma doesn't model partial indexes natively yet. We rely on app-level
  // validation in /api/processes for the "one active per flow" rule; tests
  // cover the contract. A raw migration can add the partial index later
  // without rewriting the model.
  @@index([flowId, status])
  @@map("hiring_processes")
}

// Join row between a HiringProcess and the AutomationRule[]s that fire for
// candidates in that process. `order` is the display order in the editor;
// runtime dispatch still goes through the AutomationRule's own trigger so the
// engine doesn't need to know about HiringProcess.
model HiringProcessAutomation {
  id               String         @id @default(uuid())
  processId        String         @map("process_id")
  process          HiringProcess  @relation(fields: [processId], references: [id], onDelete: Cascade)
  automationRuleId String         @map("automation_rule_id")
  automationRule   AutomationRule @relation(fields: [automationRuleId], references: [id], onDelete: Cascade)
  order            Int            @default(0)
  createdAt        DateTime       @default(now()) @map("created_at")

  @@unique([processId, automationRuleId])
  @@index([automationRuleId])
  @@map("hiring_process_automations")
}

// Configurable rule that decides when a candidate moves between stages.
// One row = "when {eventType} fires on a candidate currently in {fromStageId}
// (null = any), move them to {toStageId}". Targeted variants narrow on a
// specific Flow / Training / SchedulingConfig via {targetId}.
//
// Resolution order (src/lib/pipeline-transitions.ts):
//   1. Filter by pipelineId + eventType + enabled.
//   2. Keep rows where fromStageId is null OR equals session.pipelineStatus.
//   3. Keep rows where targetId is null OR equals the event's target id.
//   4. Pick highest priority; ties broken by most-specific (non-null
//      fromStageId beats null; non-null targetId beats null).
//   5. Apply furthest-wins guard unless allowBackward=true.
//
// If no rule matches under V2, pipelineStatus is NOT mutated.
model PipelineTransitionRule {
  id            String    @id @default(uuid())
  workspaceId   String    @map("workspace_id")
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pipelineId    String    @map("pipeline_id")
  pipeline      Pipeline  @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  // Stage id the candidate must currently be in for the rule to match.
  // Null = wildcard (matches any current stage). Stages live in
  // Pipeline.stages JSON so this is a plain string, no FK.
  fromStageId   String?   @map("from_stage_id")
  // One of StageTriggerEvent in src/lib/funnel-stages.ts (flow_completed,
  // meeting_scheduled, training_completed, etc.).
  eventType     String    @map("event_type")
  // Optional target narrowing — usually a Flow id (for flow_* events),
  // Training id (training_*), or SchedulingConfig id (meeting_*). Null =
  // wildcard.
  targetId      String?   @map("target_id")
  toStageId     String    @map("to_stage_id")
  // Higher wins when multiple rules match. Default 0; recruiters use bigger
  // numbers (e.g. 100) to make targeted rules beat workspace-wide fallbacks.
  priority      Int       @default(0)
  // When true, the rule may move a candidate backwards through the funnel
  // (toStage.order < currentStage.order). Default false so the historical
  // furthest-stage-wins guard still protects against accidental loops.
  // Recruiters opt in for legitimate rework flows: no-show recovery,
  // re-screen after a failed background check, etc.
  allowBackward Boolean   @default(false) @map("allow_backward")
  enabled       Boolean   @default(true)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  stageEntries StageEntry[]

  @@index([pipelineId, eventType, enabled])
  @@index([workspaceId])
  @@map("pipeline_transition_rules")
}

// One row per stage entry. Created every time a transition rule (or a
// recruiter's manual move under V2) actually changes Session.pipelineStatus.
// Distinct from PipelineStatusChange (which is an audit log for ANY mutation,
// including no-op legacy writes); StageEntry only captures real entries and
// is the join target for stage_entered automation idempotency:
// AutomationExecution.stageEntryId pins a send to one specific entry so
// re-entering the stage later produces a fresh execution row.
model StageEntry {
  id               String                  @id @default(uuid())
  workspaceId      String                  @map("workspace_id")
  workspace        Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pipelineId       String                  @map("pipeline_id")
  pipeline         Pipeline                @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  sessionId        String                  @map("session_id")
  session          Session                 @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  stageId          String                  @map("stage_id")
  enteredAt        DateTime                @default(now()) @map("entered_at")
  // The system event that drove this entry — e.g. 'meeting_scheduled',
  // 'flow_completed', 'manual'. Null only for backfilled/bootstrap rows.
  sourceEventType  String?                 @map("source_event_type")
  // Optional pointer to the originating event row (SchedulingEvent.id,
  // CandidateSubmission.id, etc.) for deep tracing. Free-form because the
  // source table varies by event type.
  sourceEventId    String?                 @map("source_event_id")
  transitionRuleId String?                 @map("transition_rule_id")
  transitionRule   PipelineTransitionRule? @relation(fields: [transitionRuleId], references: [id], onDelete: SetNull)
  previousStageId  String?                 @map("previous_stage_id")

  executions AutomationExecution[]

  @@index([sessionId, enteredAt])
  @@index([pipelineId, stageId])
  @@map("stage_entries")
}

model GoogleIntegration {
  id                               String    @id @default(uuid())
  workspaceId                      String    @unique @map("workspace_id")
  workspace                        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  googleEmail                      String    @map("google_email")
  // Google account ID from userinfo.id. Workspace Events Meet API sends signed-in
  // participants as `users/{id}` where {id} matches this value, so this — not the
  // email — is what we compare against to decide whether a participant is the host.
  // Nullable to keep older connections working until they reconnect or self-heal.
  googleUserId                     String?   @map("google_user_id")
  // Display name from userinfo (e.g. "Georgiy Sayapin"). Used by the Drive
  // recording-filename attendance heuristic — Meet names recordings as
  // "<Attendee A> and <Attendee B>" so we need the host's display name to
  // tell host-only recordings apart from host+candidate recordings.
  googleDisplayName                String?   @map("google_display_name")
  // Cached "Meet Recordings" Drive folder id, looked up once per integration.
  // Saves a Drive files.list call on every sync.
  meetRecordingsFolderId           String?   @map("meet_recordings_folder_id")
  refreshToken                     String    @map("refresh_token") // encrypted
  accessToken                      String?   @map("access_token") // encrypted
  accessExpiresAt                  DateTime? @map("access_expires_at")
  calendarId                       String    @default("primary") @map("calendar_id")
  watchChannelId                   String?   @unique @map("watch_channel_id")
  watchResourceId                  String?   @map("watch_resource_id")
  watchToken                       String?   @map("watch_token") // per-workspace webhook secret
  watchExpiresAt                   DateTime? @map("watch_expires_at")
  syncToken                        String?   @map("sync_token")
  lastSyncedAt                     DateTime? @map("last_synced_at")
  // ----- Meet integration v2 fields -----
  // Space-delimited scope string as returned by Google on token exchange. Read at
  // dispatch time via hasMeetScopes() to decide whether the new Meet flow is
  // available without forcing a full disconnect.
  grantedScopes                    String?   @map("granted_scopes")
  // userinfo.hd — the Google-hosted domain for the connected account. Null for
  // free @gmail.com. This is a *soft UX hint only* — never a recording signal.
  hostedDomain                     String?   @map("hosted_domain")
  // Tri-state recording capability (null = never probed). Source of truth is the
  // authoritative probe against the Meet settings API, not the hosted domain.
  recordingCapable                 Boolean?  @map("recording_capable")
  recordingCapabilityCheckedAt     DateTime? @map("recording_capability_checked_at")
  // Machine-readable reason, e.g. probe_ok, permission_denied_plan,
  // permission_denied_admin_policy, probe_not_run, probe_error.
  recordingCapabilityReason        String?   @map("recording_capability_reason")
  // Tri-state transcription capability — probed independently from recording
  // because Workspace Individual / personal Gmail commonly allows
  // autoTranscription but not autoRecording. Same probe-cache lifecycle.
  transcriptionCapable             Boolean?  @map("transcription_capable")
  transcriptionCapabilityCheckedAt DateTime? @map("transcription_capability_checked_at")
  transcriptionCapabilityReason    String?   @map("transcription_capability_reason")
  // Auth-error tracking. When a Google API call returns invalid_grant (the
  // workspace's refresh token has been revoked, most commonly because the
  // OAuth consent screen is still in "Testing" mode and Google rotates
  // refresh tokens for personal Gmail every 7 days) or invalid_client (env
  // GOOGLE_CLIENT_SECRET drifted out of sync with GCP), the calling site
  // records it here and notifies the workspace owner — once per 24h —
  // so candidate-facing scheduling silently breaking gets a human alerted
  // instead of just bubbling `free_busy_failed` to the booking form.
  authErrorAt                      DateTime? @map("auth_error_at")
  authErrorCode                    String?   @map("auth_error_code")
  authErrorNotifiedAt              DateTime? @map("auth_error_notified_at")
  createdAt                        DateTime  @default(now()) @map("created_at")
  updatedAt                        DateTime  @updatedAt @map("updated_at")

  @@map("google_integrations")
}

// ============ MEET INTEGRATION V2 ============
// A scheduled Google Meet interview created by HiringFlow. The existing
// SchedulingEvent table remains the append-only audit log; this table is the
// typed, unique-per-conference entity that the Workspace Events webhook
// correlates against and that the UI joins to the candidate timeline.
model InterviewMeeting {
  id                          String                     @id @default(uuid())
  workspaceId                 String                     @map("workspace_id")
  workspace                   Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sessionId                   String                     @map("session_id")
  session                     Session                    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  schedulingConfigId          String?                    @map("scheduling_config_id")
  // Meet resource identifiers
  meetSpaceName               String                     @unique @map("meet_space_name") // "spaces/abc..."
  meetingCode                 String?                    @map("meeting_code")
  meetingUri                  String                     @map("meeting_uri")
  // Calendar event tied to this Meet space
  googleCalendarEventId       String                     @unique @map("google_calendar_event_id")
  scheduledStart              DateTime                   @map("scheduled_start")
  scheduledEnd                DateTime                   @map("scheduled_end")
  // Set by Workspace Events conference.started / conference.ended
  actualStart                 DateTime?                  @map("actual_start")
  actualEnd                   DateTime?                  @map("actual_end")
  // Recording state
  recordingEnabled            Boolean                    @default(false) @map("recording_enabled")
  recordingProvider           String?                    @map("recording_provider") // 'google_meet' | 'recall_ai' | null
  // 'disabled' | 'requested' | 'recording' | 'processing' | 'ready' | 'failed' | 'unavailable'
  recordingState              String                     @default("disabled") @map("recording_state")
  // 'disabled' | 'processing' | 'ready' | 'failed'
  transcriptState             String                     @default("disabled") @map("transcript_state")
  driveRecordingFileId        String?                    @map("drive_recording_file_id")
  driveTranscriptFileId       String?                    @map("drive_transcript_file_id")
  // Workspace Events subscription for this space (one per space)
  workspaceEventsSubName      String?                    @map("workspace_events_sub_name")
  workspaceEventsSubExpiresAt DateTime?                  @map("workspace_events_sub_expires_at")
  // [{email, displayName, joinTime, leaveTime}] — appended by participant events
  participants                Json?
  // Capped ring buffer of recent CloudEvent payloads for debugging / replay
  rawEvents                   Json?                      @map("raw_events")
  // Timestamp of the most recent on-read sync from Meet API. Throttles repeat
  // sync attempts when many concurrent listings hit a stale meeting; null
  // means we've never synced via the API path.
  meetApiSyncedAt             DateTime?                  @map("meet_api_synced_at")
  // True if this row's Meet space was changed via reschedule adoption (the
  // calendar event's Meet link was regenerated). Diagnostic only.
  spaceAdoptedFromReschedule  Boolean                    @default(false) @map("space_adopted_from_reschedule")
  // Drive file id of the "Notes by Gemini" doc associated with this meeting
  // (when present). Personal Gmail tenants get attendance from this artifact's
  // existence even when conferenceRecords is empty.
  driveGeminiNotesFileId      String?                    @map("drive_gemini_notes_file_id")
  // Full history of every Drive artifact (recording, transcript, gemini notes)
  // we've discovered for this meeting. Reschedules that swap the Meet URL and
  // second sessions on the same link both produce extra recordings; the legacy
  // single-fileId columns above only point at one of them and the rest used to
  // be orphaned. The child rows preserve full history including the
  // meetSpaceName at the time of capture.
  artifacts                   InterviewMeetingArtifact[]
  // Set when the candidate replies YES/CONFIRM to a before_meeting SMS
  // reminder (or any future channel that lands on this row). Null until
  // confirmation. Surfaced on the candidate detail page as a green pill.
  confirmedAt                 DateTime?                  @map("confirmed_at")
  // Recall.ai bot id when this meeting is being recorded/tracked by a Recall
  // bot. Null when the workspace is on the legacy Meet auto-record + chrome-
  // extension attendance path. Populated by bookInterview /
  // adoptExternalMeet when Workspace.recallBotEnabled is true. Webhook events
  // arriving with this bot id are routed back to this meeting row.
  recallBotId                 String?                    @unique @map("recall_bot_id")
  // Recall.ai recording id for this meeting. Populated when the bot finishes
  // and reports `bot.done`. The playback URL is presigned (15 min TTL) so we
  // don't cache it — `/api/interview-meetings/[id]/recording` re-fetches it
  // from the Recall API on every play request. A v2 step (out of scope for
  // pilot) will mirror the file to R2 so playback survives a Recall account
  // change or vendor sunset.
  recallRecordingId           String?                    @map("recall_recording_id")
  // Which signal currently owns attendance + recording for this meeting:
  //   'meet'   — Workspace Events Meet API (Workspace tenants) or
  //              sync-on-read Drive fallback (personal Gmail). Default.
  //   'recall' — Recall.ai bot. Lifecycle events (meeting_started/ended/
  //              no_show), participants[], recording artifact all come
  //              from Recall webhooks. The Meet path ignores this row.
  attendanceSource            String                     @default("meet") @map("attendance_source")
  // Set when the meeting is cancelled (candidate clicked "Cancel" on a
  // booking link, or the host deleted the Google Calendar event). Used to
  // exclude the row from FreeBusy backstop queries in availability/
  // preview-conflicts — without this, a cancelled meeting kept blocking
  // the slot indefinitely. Kept as a soft delete (null = active) instead
  // of hard delete so SchedulingEvent rows referencing this meeting
  // remain auditable.
  cancelledAt                 DateTime?                  @map("cancelled_at")
  createdAt                   DateTime                   @default(now()) @map("created_at")
  updatedAt                   DateTime                   @updatedAt @map("updated_at")

  @@index([workspaceId, sessionId])
  @@index([scheduledStart])
  @@map("interview_meetings")
}

// Every Drive artifact (recording / transcript / Gemini Notes) ever
// discovered for a meeting. One InterviewMeeting can accumulate
// many rows here over its lifetime:
//   - Calendar regenerating the Meet URL mid-reschedule (artifacts get tagged
//     with the *old* meetSpaceName and remain reachable in the UI).
//   - Multiple sessions opened on the same link (e.g. host rejoined an hour
//     after the scheduled meeting ended; Drive creates a separate Recording
//     file with a later createdTime).
//
// The denormalized `drive*FileId` pointers on InterviewMeeting still point at
// one of these (the "primary" / latest), but the canonical artifact list lives
// here.
model InterviewMeetingArtifact {
  id                 String           @id @default(uuid())
  interviewMeetingId String           @map("interview_meeting_id")
  meeting            InterviewMeeting @relation(fields: [interviewMeetingId], references: [id], onDelete: Cascade)
  // 'recording' | 'transcript' | 'gemini_notes'
  kind               String
  driveFileId        String           @map("drive_file_id")
  fileName           String?          @map("file_name")
  // Meet space at the moment the artifact was discovered. Survives later
  // reschedule URL swaps so we can attribute each recording to the link it
  // actually came from.
  meetSpaceName      String?          @map("meet_space_name")
  driveCreatedTime   DateTime         @map("drive_created_time")
  discoveredAt       DateTime         @default(now()) @map("discovered_at")

  @@unique([interviewMeetingId, driveFileId])
  @@index([interviewMeetingId, kind])
  @@map("interview_meeting_artifacts")
}

// Idempotency ledger for Pub/Sub-delivered Workspace Events. Each processed
// CloudEvent is recorded once; duplicate deliveries are ack'd without
// reprocessing.
model ProcessedWorkspaceEvent {
  id            String   @id @default(uuid())
  meetSpaceName String   @map("meet_space_name")
  cloudEventId  String   @map("cloud_event_id")
  eventType     String   @map("event_type")
  processedAt   DateTime @default(now()) @map("processed_at")

  @@unique([meetSpaceName, cloudEventId])
  @@index([processedAt])
  @@map("processed_workspace_events")
}

model WorkspaceMember {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String    @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role        String    @default("owner") // 'owner' | 'admin' | 'member'
  joinedAt    DateTime  @default(now()) @map("joined_at")

  @@unique([userId, workspaceId])
  @@map("workspace_members")
}

model PlatformSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  category  String   @default("general") // 'general' | 'providers' | 'email' | 'integrations'
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}

// ============ VIDEOS ============

model Video {
  id               String            @id @default(uuid())
  workspaceId      String            @map("workspace_id")
  workspace        Workspace         @relation(fields: [workspaceId], references: [id])
  createdById      String            @map("created_by_id")
  filename         String
  storageKey       String            @map("storage_key")
  mimeType         String            @map("mime_type")
  sizeBytes        Int               @map("size_bytes")
  durationSeconds  Float?            @map("duration_seconds")
  transcript       String?
  segments         Json?
  summary          String?
  bulletPoints     String[]          @default([]) @map("bullet_points")
  displayName      String?           @map("display_name")
  kind             String            @default("training")
  // R2/HLS pipeline (added 2026-05-14). New uploads go through R2 staging →
  // Lambda transcode → R2 videos bucket. Legacy Vercel Blob videos have
  // status='ready' + hlsManifestUrl=null and continue to play from storageKey
  // via the legacy <video src> path until the migration script reprocesses
  // them. `status` values: uploading | transcoding | ready | failed.
  status           String            @default("ready")
  hlsManifestUrl   String?           @map("hls_manifest_url")
  posterUrl        String?           @map("poster_url")
  transcodeError   String?           @map("transcode_error")
  createdAt        DateTime          @default(now()) @map("created_at")
  steps            FlowStep[]
  trainingContents TrainingContent[]

  @@map("videos")
}

model Picture {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  createdById String    @map("created_by_id")
  filename    String
  storageKey  String    @map("storage_key")
  url         String
  mimeType    String    @map("mime_type")
  sizeBytes   Int       @map("size_bytes")
  displayName String?   @map("display_name")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("pictures")
}

// ============ FLOWS ============

model Flow {
  id                         String            @id @default(uuid())
  workspaceId                String            @map("workspace_id")
  workspace                  Workspace         @relation(fields: [workspaceId], references: [id])
  createdById                String            @map("created_by_id")
  name                       String
  slug                       String            @unique
  isPublished                Boolean           @default(false) @map("is_published")
  startMessage               String            @default("Welcome! Please complete the following steps.") @map("start_message")
  endMessage                 String            @default("Thank you for your participation!") @map("end_message")
  branding                   Json?
  // Plain-text job/position description used as the default input to the
  // candidate AI evaluation engine. Recruiters can paste a JD here once and
  // every evaluation run against a candidate of this flow inherits it. Null
  // falls back to the linked Ad copy (headline + bodyText + requirements +
  // benefits), and finally to the flow name. See
  // src/lib/evaluation/position-description.ts.
  positionDescription        String?           @map("position_description")
  // Per-flow timeouts (days/hours) consumed by the cron stalled detector.
  // Null → use the platform DEFAULT_TIMEOUTS in src/lib/candidate-status.ts.
  // Roles with longer hiring loops (e.g. specialty trades) can extend these
  // without affecting other flows in the same workspace.
  videoInterviewTimeoutDays  Int?              @map("video_interview_timeout_days")
  trainingTimeoutDays        Int?              @map("training_timeout_days")
  noShowTimeoutHours         Int?              @map("no_show_timeout_hours")
  schedulingTimeoutHours     Int?              @map("scheduling_timeout_hours")
  backgroundCheckTimeoutDays Int?              @map("background_check_timeout_days")
  // Which Pipeline (funnel stage list) this flow's candidates flow through.
  // Null falls back to the workspace's default pipeline so existing flows
  // keep working without an explicit assignment. Roles with different
  // hiring loops point at different pipelines (e.g. Cleaner → with-training,
  // Dispatcher → no-training).
  pipelineId                 String?           @map("pipeline_id")
  pipeline                   Pipeline?         @relation(fields: [pipelineId], references: [id], onDelete: SetNull)
  // User-facing classification of what this workflow is: an Application
  // form, an Interview, an Assessment, a Training course, a Survey, or a
  // Custom one-off. Drives the workflow-list filter and the workflow card's
  // type badge — no functional change to the flow engine itself, every
  // type runs through the same step executor. Nullable for back-compat
  // (existing flows default to 'application' at the API layer).
  workflowType               String?           @map("workflow_type")
  // Schema-view canvas layout: { [stepId]: { x: number, y: number } }.
  // Persists the user's manual arrangement of cards so reopening the schema
  // restores their layout instead of re-running BFS from scratch.
  canvasLayout               Json?             @map("canvas_layout")
  createdAt                  DateTime          @default(now()) @map("created_at")
  steps                      FlowStep[]
  sessions                   Session[]
  ads                        Ad[]
  automationRules            AutomationRule[]
  captureResponses           CaptureResponse[]
  hiringProcesses            HiringProcess[]

  @@index([pipelineId])
  @@map("flows")
}

model Ad {
  id           String      @id @default(uuid())
  workspaceId  String      @map("workspace_id")
  workspace    Workspace   @relation(fields: [workspaceId], references: [id])
  createdById  String      @map("created_by_id")
  name         String
  source       String // 'indeed' | 'facebook' | 'craigslist' | 'google' | 'linkedin' | 'other'
  campaign     String?
  // Free-text role this ad is hiring for (e.g. "Dispatcher", "Cleaner").
  // Drives the Campaigns page position-grouped overview and the
  // ?targetPosition= filter on Candidates / Analytics. Null = "Unassigned".
  targetPosition String?   @map("target_position")
  flowId       String      @map("flow_id")
  flow         Flow        @relation(fields: [flowId], references: [id])
  slug         String      @unique
  imageUrl     String?     @map("image_url")
  placementUrl String?     @map("placement_url")
  templateId   String?     @map("template_id")
  template     AdTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  headline     String?
  bodyText     String?     @map("body_text")
  requirements String?
  benefits     String?
  callToAction String?     @map("call_to_action")
  notes        String? // private — not shown on public landing page
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  sessions     Session[]

  @@map("ads")
}

model FlowStep {
  id               String                @id @default(uuid())
  flowId           String                @map("flow_id")
  flow             Flow                  @relation(fields: [flowId], references: [id], onDelete: Cascade)
  title            String
  videoId          String?               @map("video_id")
  video            Video?                @relation(fields: [videoId], references: [id])
  questionText     String?               @map("question_text")
  stepOrder        Int                   @default(0) @map("step_order")
  // Step kinds: 'question' (default) | 'form' | 'info' | 'submission' (legacy
  // video-answer) | 'capture' (generic Capture Engine — audio/video/text/upload
  // shape lives in captureConfig). Legacy 'submission' steps remain on the
  // CandidateSubmission table and are NOT touched by the capture pipeline.
  stepType         String                @default("question") @map("step_type")
  questionType     String                @default("single") @map("question_type")
  formEnabled      Boolean               @default(false) @map("form_enabled")
  formConfig       Json?                 @map("form_config")
  infoContent      String?               @map("info_content")
  buttonConfig     Json?                 @map("button_config")
  combinedWithId   String?               @map("combined_with_id")
  captionsEnabled  Boolean               @default(false) @map("captions_enabled")
  captionStyle     Json?                 @map("caption_style")
  // Validated by parseCaptureConfig (src/lib/capture/capture-config.ts). Shape:
  //   { mode, prompt, required, maxDurationSec?, minDurationSec?,
  //     allowRetake, maxRetakes?, transcriptionEnabled, aiAnalysisEnabled }
  // Only meaningful when stepType='capture'. Stored as JSON so the builder can
  // evolve fields without per-column migrations; never trust raw JSON outside
  // of the validator.
  captureConfig    Json?                 @map("capture_config")
  createdAt        DateTime              @default(now()) @map("created_at")
  options          StepOption[]          @relation("StepOptions")
  incomingOptions  StepOption[]          @relation("NextStep")
  answers          SessionAnswer[]
  submissions      CandidateSubmission[]
  captureResponses CaptureResponse[]
  sessions         Session[]             @relation("LastStep")

  @@map("flow_steps")
}

model StepOption {
  id         String          @id @default(uuid())
  stepId     String          @map("step_id")
  step       FlowStep        @relation("StepOptions", fields: [stepId], references: [id], onDelete: Cascade)
  optionText String          @map("option_text")
  nextStepId String?         @map("next_step_id")
  nextStep   FlowStep?       @relation("NextStep", fields: [nextStepId], references: [id], onDelete: SetNull)
  createdAt  DateTime        @default(now()) @map("created_at")
  answers    SessionAnswer[]

  @@map("step_options")
}

// ============ SESSIONS / CANDIDATES ============

model Session {
  id                      String                 @id @default(uuid())
  workspaceId             String                 @map("workspace_id")
  workspace               Workspace              @relation(fields: [workspaceId], references: [id])
  flowId                  String                 @map("flow_id")
  flow                    Flow                   @relation(fields: [flowId], references: [id], onDelete: Cascade)
  candidateName           String?                @map("candidate_name")
  candidateEmail          String?                @map("candidate_email")
  candidatePhone          String?                @map("candidate_phone")
  formData                Json?                  @map("form_data")
  startedAt               DateTime               @default(now()) @map("started_at")
  finishedAt              DateTime?              @map("finished_at")
  // Heartbeat — bumped whenever the candidate POSTs to a public flow / training
  // / quiz endpoint. Recruiters use this to see if a candidate is actively
  // engaging right now or has gone quiet. Distinct from `startedAt` (creation)
  // and `finishedAt` (flow completion) because it covers post-flow activity
  // like training and quiz progress.
  //
  // NB: `lastActivityAt` is bumped on passive signals too (opening a training
  // landing page, viewing a public link). Do NOT use it for stale-detection —
  // that uses `lastProgressAt` below, which is bumped only on real forward
  // progress.
  lastActivityAt          DateTime?              @map("last_activity_at")
  // Real forward-progress timestamp — bumped only when the candidate does
  // something that demonstrably moves them through the funnel: submits an
  // answer, completes the flow, starts/progresses a training step, books a
  // meeting, attends a meeting, submits a background check. Passive page
  // opens are deliberately excluded so the stale-detection cron can trust
  // this column as the inactivity clock.
  //
  // Initialized at session create-time to `startedAt`. Read by
  // /api/cron/detect-stalled to compute "candidate has been inactive for >N
  // days". See src/lib/session-activity.ts:bumpSessionProgress for the writer
  // and src/lib/candidate-status.ts:STALE_DETECTION_DEFAULT_DAYS for the
  // platform fallback when Workspace.defaultStalledDays is null.
  lastProgressAt          DateTime?              @map("last_progress_at")
  outcome                 String? // 'completed' | 'passed' | 'failed' | 'abandoned'
  pipelineStatus          String?                @map("pipeline_status")
  // Status axis — orthogonal to pipelineStatus (which is the funnel STAGE id).
  // Lets a candidate sit at `stage='video_interview_sent'` with `status='stalled'`
  // so the board can hide them without losing the historical "where they got
  // to" signal. Enum: 'active' | 'waiting' | 'stalled' | 'nurture' | 'lost' |
  // 'hired'. Source of truth lives in src/lib/candidate-status.ts. Default is
  // 'active' so newly-created sessions show up in the active pool by default.
  status                  String                 @default("active")
  // Structured drop-off / loss reason. Distinct from `rejectionReason` (which
  // stays as a recruiter-editable free-form note) — the enum is what
  // analytics groups by. Enum: see CandidateDispositionReason in
  // src/lib/candidate-status.ts. Nullable because most active candidates
  // don't have a reason.
  dispositionReason       String?                @map("disposition_reason")
  // Lifecycle stamps for the status transitions. Set by manual lifecycle
  // actions and by the cron stalled detector / no-show handler. Cleared on
  // reactivate. Used by analytics for time-in-state aggregations.
  stalledAt               DateTime?              @map("stalled_at")
  lostAt                  DateTime?              @map("lost_at")
  hiredAt                 DateTime?              @map("hired_at")
  // Free-form reason captured when a candidate lands in a Rejected-style
  // stage. Auto-set to 'No-show' by the no-show detection; otherwise editable
  // from the candidate page (predefined options + custom string).
  rejectionReason         String?                @map("rejection_reason")
  rejectionReasonAt       DateTime?              @map("rejection_reason_at")
  // Central automation kill-switch. When set, the automation guard blocks
  // every candidate-facing send for this session regardless of status, stage,
  // or trigger — see src/lib/automation-guard.ts. Set by the stalled/lost/
  // hired/archived lifecycle transitions and by manual operator halts /
  // compliance holds. Clearing reactivates automations.
  automationsHaltedAt     DateTime?              @map("automations_halted_at")
  automationsHaltedReason String?                @map("automations_halted_reason")
  lastStepId              String?                @map("last_step_id")
  lastStep                FlowStep?              @relation("LastStep", fields: [lastStepId], references: [id])
  adId                    String?                @map("ad_id")
  ad                      Ad?                    @relation(fields: [adId], references: [id])
  campaign                String?
  source                  String?
  // True when the candidate was created via the "Add candidate" modal
  // (recruiter-entered) rather than self-applying through a flow. Distinct
  // from `source`, which is now user-selectable (Indeed/Facebook/custom).
  addedManually           Boolean                @default(false) @map("added_manually")
  // Recruiter shortlist flag — when set, the candidate is "starred" in the
  // dashboard. Orthogonal to status / pipelineStatus: a recruiter can flag
  // anyone (active, stalled, lost) as interesting to revisit later. Stamp
  // doubles as the sort key so the most recently flagged candidates surface
  // first when filtering by interesting.
  interestingAt           DateTime?              @map("interesting_at")
  // Hiring Process this session belongs to. Set at session create time when
  // the candidate enters through a flow that's wired to a single active
  // HiringProcess (see /api/public/sessions). Stays null for:
  //   - sessions on flows with no active process
  //   - sessions on flows with multiple active processes (ambiguous — logged
  //     as a warning; app-layer validation in /api/processes prevents this)
  //   - manually-added candidates (recruiter chooses the flow, not a process)
  // Once set, the value is sticky — manual flow reassignments do NOT rewrite
  // processId. The candidate's journey was started under this process and
  // analytics need the historical attribution.
  processId               String?                @map("process_id")
  process                 HiringProcess?         @relation(fields: [processId], references: [id])
  answers                 SessionAnswer[]
  submissions             CandidateSubmission[]
  trainingEnrollments     TrainingEnrollment[]
  trainingAccessTokens    TrainingAccessToken[]  @relation("AccessTokenSession")
  schedulingEvents        SchedulingEvent[]
  aiCalls                 AICall[]
  interviewMeetings       InterviewMeeting[]
  notes                   CandidateNote[]
  backgroundChecks        BackgroundCheck[]
  pipelineStatusChanges   PipelineStatusChange[]
  captureResponses        CaptureResponse[]
  stageEntries            StageEntry[]
  aiCallCandidates        AICallCandidate[]
  evaluations             CandidateEvaluation[]

  // Composite index for the board's default "active candidates" filter and
  // for the cron stalled detector's per-workspace sweep — both query by
  // workspaceId + status repeatedly.
  @@index([workspaceId, status])
  @@index([workspaceId, processId])
  @@map("sessions")
}

// Audit log for every Session.pipelineStatus mutation. Written by the
// setPipelineStatus / recordPipelineStatusChange helpers in lib/pipeline-status.ts;
// never written directly. Lets us answer "what moved this candidate, and when"
// without forensics — particularly important because pipelineStatus is touched
// from many places (auto stage triggers, kanban drag, manual PATCH, backfill,
// scheduling helper). `source` is a structured tag identifying the writer
// (e.g. 'auto:meeting_no_show', 'manual:patch', 'backfill', 'scheduling').
model PipelineStatusChange {
  id          String   @id @default(uuid())
  sessionId   String   @map("session_id")
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  fromStatus  String?  @map("from_status")
  toStatus    String   @map("to_status")
  source      String
  triggeredBy String?  @map("triggered_by")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([sessionId, createdAt])
  @@map("pipeline_status_change")
}

model SessionAnswer {
  id         String      @id @default(uuid())
  sessionId  String      @map("session_id")
  session    Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  stepId     String      @map("step_id")
  step       FlowStep    @relation(fields: [stepId], references: [id])
  optionId   String?     @map("option_id")
  option     StepOption? @relation(fields: [optionId], references: [id])
  answeredAt DateTime    @default(now()) @map("answered_at")

  @@index([sessionId, stepId])
  @@map("session_answers")
}

model CandidateSubmission {
  id              String   @id @default(uuid())
  sessionId       String   @map("session_id")
  session         Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  stepId          String   @map("step_id")
  step            FlowStep @relation(fields: [stepId], references: [id])
  videoStorageKey String?  @map("video_storage_key")
  videoFilename   String?  @map("video_filename")
  videoMimeType   String?  @map("video_mime_type")
  videoSizeBytes  Int?     @map("video_size_bytes")
  textMessage     String?  @map("text_message")
  submittedAt     DateTime @default(now()) @map("submitted_at")

  @@unique([sessionId, stepId])
  @@map("candidate_submissions")
}

// Recruiter-authored notes on a candidate. authorId/authorName are
// snapshot strings (no FK relation to keep it simple and so a deleted
// user doesn't cascade-delete the note's authorship).
model CandidateNote {
  id          String   @id @default(uuid())
  sessionId   String   @map("session_id")
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  workspaceId String   @map("workspace_id")
  authorId    String?  @map("author_id")
  authorName  String?  @map("author_name")
  body        String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([sessionId, createdAt])
  @@map("candidate_notes")
}

// ============ TRAININGS ============

model Training {
  id              String                @id @default(uuid())
  workspaceId     String                @map("workspace_id")
  workspace       Workspace             @relation(fields: [workspaceId], references: [id])
  createdById     String                @map("created_by_id")
  title           String
  slug            String                @unique
  description     String?
  coverImage      String?               @map("cover_image")
  timeLimit       Json?                 @map("time_limit")
  pricing         Json?
  passingGrade    Int                   @default(80) @map("passing_grade")
  isPublished     Boolean               @default(false) @map("is_published")
  accessMode      String                @default("public") @map("access_mode")
  sectionOrder    String                @default("sequential") @map("section_order")
  branding        Json?
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")
  sections        TrainingSection[]
  enrollments     TrainingEnrollment[]
  accessTokens    TrainingAccessToken[]
  automationRules AutomationRule[]
  automationSteps AutomationStep[]      @relation("StepTraining")
  hiringProcesses HiringProcess[]

  @@map("trainings")
}

model TrainingSection {
  id         String            @id @default(uuid())
  trainingId String            @map("training_id")
  training   Training          @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  title      String
  kind       String            @default("video")
  sortOrder  Int               @default(0) @map("sort_order")
  createdAt  DateTime          @default(now()) @map("created_at")
  contents   TrainingContent[]
  quiz       TrainingQuiz?

  @@map("training_sections")
}

model TrainingContent {
  id            String          @id @default(uuid())
  sectionId     String          @map("section_id")
  section       TrainingSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  type          String
  sortOrder     Int             @default(0) @map("sort_order")
  videoId       String?         @map("video_id")
  video         Video?          @relation(fields: [videoId], references: [id])
  requiredWatch Boolean         @default(true) @map("required_watch")
  autoplayNext  Boolean         @default(true) @map("autoplay_next")
  textContent   String?         @map("text_content")
  createdAt     DateTime        @default(now()) @map("created_at")

  @@map("training_contents")
}

model TrainingQuiz {
  id              String             @id @default(uuid())
  sectionId       String             @unique @map("section_id")
  section         TrainingSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  title           String
  requiredPassing Boolean            @default(true) @map("required_passing")
  passingGrade    Int                @default(80) @map("passing_grade")
  // 'none' (just pass/fail score), 'correctness' (per-question right/wrong),
  // 'explanation' (per-question right/wrong + per-option hint).
  feedbackMode    String             @default("correctness") @map("feedback_mode")
  createdAt       DateTime           @default(now()) @map("created_at")
  questions       TrainingQuestion[]

  @@map("training_quizzes")
}

model TrainingQuestion {
  id           String       @id @default(uuid())
  quizId       String       @map("quiz_id")
  quiz         TrainingQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  questionText String       @map("question_text")
  questionType String       @default("single") @map("question_type")
  sortOrder    Int          @default(0) @map("sort_order")
  options      Json
  createdAt    DateTime     @default(now()) @map("created_at")

  @@map("training_questions")
}

model TrainingEnrollment {
  id            String               @id @default(uuid())
  trainingId    String               @map("training_id")
  training      Training             @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  userName      String?              @map("user_name")
  userEmail     String?              @map("user_email")
  sessionId     String?              @map("session_id")
  session       Session?             @relation(fields: [sessionId], references: [id])
  accessTokenId String?              @map("access_token_id")
  accessToken   TrainingAccessToken? @relation(fields: [accessTokenId], references: [id])
  status        String               @default("not_started")
  progress      Json?
  startedAt     DateTime             @default(now()) @map("started_at")
  completedAt   DateTime?            @map("completed_at")

  @@unique([trainingId, accessTokenId])
  @@map("training_enrollments")
}

model TrainingAccessToken {
  id          String               @id @default(uuid())
  token       String               @unique
  candidateId String?              @map("candidate_id")
  candidate   Session?             @relation("AccessTokenSession", fields: [candidateId], references: [id])
  trainingId  String               @map("training_id")
  training    Training             @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  sourceType  String               @default("automation") @map("source_type")
  sourceRefId String?              @map("source_ref_id")
  status      String               @default("active")
  expiresAt   DateTime?            @map("expires_at")
  usedAt      DateTime?            @map("used_at")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  enrollments TrainingEnrollment[]

  @@map("training_access_tokens")
}

// ============ AI CALLS ============

model AICallConfig {
  id            String    @id @default(uuid())
  workspaceId   String    @map("workspace_id")
  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  createdById   String    @map("created_by_id")
  name          String
  slug          String    @unique
  agentId       String    @map("agent_id") // ElevenLabs agent ID
  requiredCalls Int       @default(1) @map("required_calls")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  calls         AICall[]

  @@map("ai_call_configs")
}

model AICall {
  id             String       @id @default(uuid())
  configId       String       @map("config_id")
  config         AICallConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  sessionId      String?      @map("session_id")
  session        Session?     @relation(fields: [sessionId], references: [id])
  candidateName  String?      @map("candidate_name")
  candidateEmail String?      @map("candidate_email")
  callNumber     Int          @default(1) @map("call_number")
  status         String       @default("pending") // 'pending' | 'in_progress' | 'completed' | 'failed'
  durationSecs   Int?         @map("duration_secs")
  transcript     Json?
  evaluation     Json? // AI evaluation results
  startedAt      DateTime?    @map("started_at")
  completedAt    DateTime?    @map("completed_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@map("ai_calls")
}

model AICallCandidate {
  id              String    @id @default(uuid())
  workspaceId     String    @map("workspace_id")
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  name            String
  agentId         String    @map("agent_id")
  conversationIds String[]  @default([]) @map("conversation_ids") // ElevenLabs conversation IDs
  // Optional link to a HiringFlow candidate (Session). When set, the AI call
  // record is "attached" to that candidate and surfaces under their detail
  // page; transcripts feed the candidate evaluation engine. Null = unattached
  // (the recruiter created the agent link before knowing which candidate
  // would use it, or the candidate was a one-off test).
  sessionId       String?   @map("session_id")
  session         Session?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([workspaceId, sessionId])
  @@map("ai_call_candidates")
}

// AI-generated candidate evaluation. Persisted so the Analytics > AI Evaluation
// page can compare candidates without re-running OpenAI on every render. Each
// row is the result of a single evaluation pass — the recruiter can re-run
// (writes a fresh row) and the comparison table picks the latest per session.
//
// Criteria are dynamic: the engine first asks the model to derive role-specific
// criteria from the position description, then scores each one 0-100. So a
// "Cleaner" evaluation surfaces different criteria than "Dispatcher".
model CandidateEvaluation {
  id                          String    @id @default(uuid())
  workspaceId                 String    @map("workspace_id")
  workspace                   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sessionId                   String    @map("session_id")
  session                     Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  // Snapshot of the JD used for this run, so re-rating a candidate after the
  // JD changes still lets the recruiter see what was scored against.
  positionDescriptionSnapshot String    @map("position_description_snapshot")
  model                       String    @default("gpt-4o-mini")
  overallScore                Int       @map("overall_score") // 0..100, weighted average
  recommendation              String // 'strong_hire' | 'hire' | 'borderline' | 'no_hire'
  summary                     String
  // Array of { name, description, weight, score, evidence }. Shape derived
  // from the JD by the model, validated by parseEvaluationResult in
  // src/lib/evaluation/engine.ts.
  criteria                    Json
  strengths                   Json // string[]
  weaknesses                  Json // string[]
  // The 3-6 outcome-driving behaviors the rubric was built from
  // (string[]). Persisted so the recruiter can see WHY a given rubric was
  // chosen — e.g. "convert inbound leads into booked appointments" leading
  // to the "Booking Conversion" criterion. Nullable because evaluations
  // created before the success-factor layer (pre-2026-06-04) don't have one.
  roleSuccessFactors          Json?     @map("role_success_factors")
  // 4-8 sentence pre-scoring analysis the model wrote BEFORE committing to
  // numeric scores. Surfaced in the UI as a "Reasoning" block. Nullable
  // because evaluations created before the analysis field landed don't
  // have one.
  analysis                    String?
  // string[] of data modalities that were missing for this candidate
  // (e.g. "no AI-call transcript", "no video self-intro"). Drives the
  // coverage discount — when entire modalities are missing, the candidate's
  // overall score is downgraded relative to peers with full material.
  coverageGaps                Json?     @map("coverage_gaps")
  // Provenance metadata: which transcripts went into the prompt. Shape:
  // { meetings: [{id, durationSec, hasTranscript}],
  //   aiCalls: [{conversationId, durationSecs, hasTranscript}],
  //   captures: [{id, mode, hasTranscript}] }
  sources                     Json
  // Whether this run included multimodal media observation (separate from
  // transcript scoring). Observations are descriptive only — pace, clarity,
  // hesitation, energy, articulation for voice; camera presence, presentation,
  // engagement for video. Never claims trustworthiness/honesty/attractiveness.
  includeVoice                Boolean   @default(false) @map("include_voice")
  includeVideo                Boolean   @default(false) @map("include_video")
  // Shape: { clips: [{ assetType: 'capture' | 'ai_call' | 'meeting',
  //                    assetId, durationSec, pace, clarity, hesitation,
  //                    energy, articulation, evidence: string[] }],
  //          summary: string }
  // Null when includeVoice=false. See src/lib/evaluation/media-observation.ts.
  voiceObservation            Json?     @map("voice_observation")
  // Shape: { clips: [{ assetType, assetId, durationSec,
  //                    cameraPresence, presentation, engagement,
  //                    evidence: string[] }],
  //          summary: string }
  // Null when includeVideo=false.
  videoObservation            Json?     @map("video_observation")
  createdById                 String?   @map("created_by_id")
  createdAt                   DateTime  @default(now()) @map("created_at")

  @@index([workspaceId, sessionId, createdAt(sort: Desc)])
  @@map("candidate_evaluations")
}

// Cache for multimodal media observation calls. Voice and video observation
// runs through OpenAI gpt-4o (audio + vision) which is expensive per minute
// of input. A candidate's self-intro recording doesn't change between
// evaluation re-runs — so we key the result by (asset, model, version) and
// reuse it. Recruiter can force-refresh later via a "Re-analyze media"
// button (out of scope for the first PR).
//
// `assetType` is one of: 'capture' (CaptureResponse), 'ai_call' (ElevenLabs
// conversation), 'meeting' (Recall.ai recording). `assetId` is the source
// row's id (CaptureResponse.id / conversationId / InterviewMeeting.id).
// `kind` is 'voice' or 'video' so the same asset can have both cached.
// `analysisVersion` bumps when the prompt/spec changes — invalidates the
// whole cache without a manual purge.
model MediaAnalysisCache {
  id              String   @id @default(uuid())
  workspaceId     String   @map("workspace_id")
  assetType       String   @map("asset_type") // 'capture' | 'ai_call' | 'meeting'
  assetId         String   @map("asset_id")
  kind            String   // 'voice' | 'video'
  model           String   // e.g. 'gpt-4o-audio-preview', 'gpt-4o'
  analysisVersion Int      @default(1) @map("analysis_version")
  result          Json
  durationSec     Float?   @map("duration_sec")
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([workspaceId, assetType, assetId, kind, model, analysisVersion])
  @@index([workspaceId, assetType, assetId])
  @@map("media_analysis_cache")
}

// ============ AD TEMPLATES ============

model AdTemplate {
  id           String    @id @default(uuid())
  workspaceId  String    @map("workspace_id")
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  createdById  String    @map("created_by_id")
  name         String
  source       String // 'indeed' | 'facebook' | 'craigslist' | 'google' | 'linkedin' | 'other' | 'general'
  headline     String
  bodyText     String    @map("body_text")
  requirements String?
  benefits     String?
  callToAction String?   @map("call_to_action")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  ads          Ad[]

  @@map("ad_templates")
}

// ============ EMAIL & AUTOMATIONS ============

model EmailTemplate {
  id          String           @id @default(uuid())
  workspaceId String           @map("workspace_id")
  workspace   Workspace        @relation(fields: [workspaceId], references: [id])
  createdById String           @map("created_by_id")
  name        String
  subject     String
  bodyHtml    String           @map("body_html")
  bodyText    String?          @map("body_text")
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  automations AutomationRule[]
  steps       AutomationStep[]

  // Names must be unique per workspace. Without this, the seed endpoint
  // running twice (or a recruiter retrying a POST) produced multiple rows
  // with the same display name — see the "Next Step × 3 / Training
  // Invitation × 2" cleanup on 2026-06-04. POST /api/email-templates
  // translates the P2002 conflict into a 409 so the UI can surface
  // "Name already in use".
  @@unique([workspaceId, name])
  @@map("email_templates")
}

// Mirrors EmailTemplate for the SMS channel. The original v1 of the
// automation engine stored SMS bodies inline on the AutomationStep
// (step.smsBody) — that field is kept as a fallback for steps that haven't
// been migrated to a named template yet, and as a cache when the recruiter
// types a one-off body without saving it as a template.
model SmsTemplate {
  id          String           @id @default(uuid())
  workspaceId String           @map("workspace_id")
  workspace   Workspace        @relation(fields: [workspaceId], references: [id])
  createdById String           @map("created_by_id")
  name        String
  body        String
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  steps       AutomationStep[]

  // Same per-workspace name uniqueness as EmailTemplate.
  @@unique([workspaceId, name])
  @@map("sms_templates")
}

model AutomationRule {
  id                      String                @id @default(uuid())
  workspaceId             String                @map("workspace_id")
  workspace               Workspace             @relation(fields: [workspaceId], references: [id])
  createdById             String                @map("created_by_id")
  name                    String
  triggerType             String                @map("trigger_type")
  // Explicit funnel-stage assignment for the journey UI. The runtime engine
  // still dispatches by triggerType — stageId is just metadata that says
  // "this rule belongs to stage X in the applicant journey", overriding the
  // implicit triggerType→StageTrigger mapping. Nullable for back-compat:
  // older rules fall back to the implicit mapping. Stages live in JSON on
  // Workspace.settings, so this is intentionally a plain string (no FK).
  stageId                 String?               @map("stage_id")
  flowId                  String?               @map("flow_id")
  flow                    Flow?                 @relation(fields: [flowId], references: [id])
  // Pipeline scope. When set, the rule only matches candidates whose flow's
  // pipeline (`Flow.pipelineId`, falling back to the workspace default) is
  // this one. Null = "any pipeline" — the rule applies workspace-wide,
  // preserving back-compat for rules created before multi-pipeline. The
  // dispatch helpers (fireMeetingLifecycleAutomations, dispatchRulesForTrigger,
  // scheduleBeforeMeetingReminders, the meeting_ended branch, and the manual
  // run-stage-automations matcher) all enforce this via pipelineWhereForCandidate
  // in src/lib/automation-pipeline-scope.ts.
  pipelineId              String?               @map("pipeline_id")
  pipeline                Pipeline?             @relation(fields: [pipelineId], references: [id], onDelete: SetNull)
  triggerAutomationId     String?               @map("trigger_automation_id")
  triggerAutomation       AutomationRule?       @relation("AutomationChain", fields: [triggerAutomationId], references: [id])
  chainedBy               AutomationRule[]      @relation("AutomationChain")
  actionType              String                @default("send_email") @map("action_type")
  // 'email' (default) | 'sms'. Determines which send pipeline runs. Email
  // rules use emailTemplateId; SMS rules use smsBody (per-rule, no template
  // indirection in v1). Future channels: 'whatsapp'.
  channel                 String                @default("email")
  // Nullable for SMS rules. Required when channel='email' (validated at
  // API layer; the FK stays nullable for back-compat with future channels
  // that don't use email templates).
  emailTemplateId         String?               @map("email_template_id")
  emailTemplate           EmailTemplate?        @relation(fields: [emailTemplateId], references: [id])
  // Plaintext SMS body with merge tokens like {{candidate_name}}. Only used
  // when channel='sms'. Kept on the rule for v1 — no separate SmsTemplate
  // model yet.
  smsBody                 String?               @map("sms_body")
  emailDestination        String                @default("applicant") @map("email_destination") // 'applicant' | 'company' | 'specific'
  emailDestinationAddress String?               @map("email_destination_address")
  nextStepType            String?               @map("next_step_type")
  nextStepUrl             String?               @map("next_step_url")
  trainingId              String?               @map("training_id")
  training                Training?             @relation(fields: [trainingId], references: [id])
  schedulingConfigId      String?               @map("scheduling_config_id")
  schedulingConfig        SchedulingConfig?     @relation(fields: [schedulingConfigId], references: [id])
  delayMinutes            Int                   @default(0) @map("delay_minutes") // 0 = immediate
  // For triggerType='before_meeting' rules: how many minutes before
  // InterviewMeeting.scheduledStart to fire. e.g. 60 = "1 hour before".
  // Ignored for all other trigger types.
  minutesBefore           Int?                  @map("minutes_before")
  // When a meeting_ended rule has this set, execution is deferred until a
  // recording_ready event fires for the same session (or a 4h hard cutoff).
  waitForRecording        Boolean               @default(false) @map("wait_for_recording")
  // Lifecycle statuses for which this rule is allowed to send (in addition
  // to the default "active" candidates). Use for goodbye emails or compliance
  // notifications that intentionally fire to stalled/lost/hired candidates.
  // Empty array = rule blocked for non-active statuses (the safe default).
  // Read by src/lib/automation-guard.ts; no UI exposes this yet — set in code
  // only.
  allowedForStatuses      String[]              @default([]) @map("allowed_for_statuses")
  isActive                Boolean               @default(true) @map("is_active")
  createdAt               DateTime              @default(now()) @map("created_at")
  updatedAt               DateTime              @updatedAt @map("updated_at")
  executions              AutomationExecution[]
  steps                   AutomationStep[]
  hiringProcesses         HiringProcessAutomation[]

  @@index([pipelineId])
  @@map("automation_rules")
}

// One send within an AutomationRule. A rule is now a *sequence* of steps
// instead of a single send: the trigger fires the rule, then each step is
// queued at its own delayMinutes (relative to the trigger event). channel
// can be 'email', 'sms', or 'both' — 'both' produces one AutomationExecution
// row per channel at run time.
//
// Existing rules are backfilled to a single step at order=0 carrying the
// rule's prior channel/body/template/destination/nextStep* fields. The
// legacy per-rule fields (channel, smsBody, emailTemplateId, etc.) remain on
// AutomationRule for back-compat with read paths during rollout but are no
// longer the source of truth — the executor reads from steps.
model AutomationStep {
  id                      String                @id @default(uuid())
  ruleId                  String                @map("rule_id")
  rule                    AutomationRule        @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  order                   Int
  // How `delayMinutes` is interpreted:
  //  - 'trigger'        → minutes after the trigger event fired (default).
  //  - 'before_meeting' → minutes BEFORE InterviewMeeting.scheduledStart.
  //  - 'after_meeting'  → minutes AFTER InterviewMeeting.scheduledStart.
  // Only meaningful for triggers tied to a meeting (meeting_scheduled,
  // before_meeting, meeting_started, meeting_ended). Other triggers ignore
  // any non-'trigger' value and behave as 'trigger'.
  timingMode              String                @default("trigger") @map("timing_mode")
  delayMinutes            Int                   @default(0) @map("delay_minutes")
  // 'email' | 'sms' | 'both'. 'both' fans out into two executions at run time.
  channel                 String                @default("email")
  emailTemplateId         String?               @map("email_template_id")
  emailTemplate           EmailTemplate?        @relation(fields: [emailTemplateId], references: [id])
  // Resolved at send time: smsTemplate.body when smsTemplateId is set,
  // otherwise smsBody as a fallback for legacy/one-off bodies.
  smsTemplateId           String?               @map("sms_template_id")
  smsTemplate             SmsTemplate?          @relation(fields: [smsTemplateId], references: [id])
  smsBody                 String?               @map("sms_body")
  emailDestination        String                @default("applicant") @map("email_destination")
  emailDestinationAddress String?               @map("email_destination_address")
  // SMS destination — mirrors email's three options. 'applicant' sends to
  // session.candidatePhone; 'company' sends to workspace.phone; 'specific'
  // sends to smsDestinationNumber. Allows recruiters to alert themselves
  // (or a hiring manager) on lifecycle events instead of pinging the
  // candidate.
  smsDestination          String                @default("applicant") @map("sms_destination")
  smsDestinationNumber    String?               @map("sms_destination_number")
  // Per-step next-step config (for steps that include a scheduling/training
  // CTA in the body — e.g. the post-training scheduling-invite step).
  nextStepType            String?               @map("next_step_type")
  nextStepUrl             String?               @map("next_step_url")
  trainingId              String?               @map("training_id")
  training                Training?             @relation("StepTraining", fields: [trainingId], references: [id])
  schedulingConfigId      String?               @map("scheduling_config_id")
  schedulingConfig        SchedulingConfig?     @relation("StepSchedulingConfig", fields: [schedulingConfigId], references: [id])
  createdAt               DateTime              @default(now()) @map("created_at")
  updatedAt               DateTime              @updatedAt @map("updated_at")
  executions              AutomationExecution[]

  @@unique([ruleId, order])
  @@map("automation_steps")
}

model AutomationExecution {
  id                   String          @id @default(uuid())
  automationRuleId     String          @map("automation_rule_id")
  automationRule       AutomationRule  @relation(fields: [automationRuleId], references: [id], onDelete: Cascade)
  // Nullable for back-compat with pre-migration executions that predate the
  // step model. New rows MUST set stepId — backfilled for legacy rows.
  stepId               String?         @map("step_id")
  // SetNull (not Cascade) so editing a rule and replacing its steps doesn't
  // wipe the execution history. Orphan rows keep their ruleId, sessionId,
  // status, providerMessageId, sentAt — stepId becomes null, which is fine
  // since the unique constraint allows nulls.
  step                 AutomationStep? @relation(fields: [stepId], references: [id], onDelete: SetNull)
  sessionId            String?         @map("session_id")
  status               String          @default("pending")
  errorMessage         String?         @map("error_message")
  // 'sendgrid' for email, 'sigcore' for SMS via the Sigcore platform API.
  provider             String          @default("sendgrid")
  providerMessageId    String?         @map("provider_message_id")
  // Mirror of the step's channel at execution time. Lets the timeline UI
  // show which channel actually ran without joining to the step (its channel
  // could change after execution). For step.channel='both', each channel
  // gets its own execution row with channel='email' or 'sms'.
  channel              String          @default("email")
  // QStash messageId — captured when a delayed rule is queued so we can
  // cancel/delete the scheduled job (e.g. when a meeting is cancelled or
  // rescheduled and pending reminders need to be voided).
  qstashMessageId      String?         @map("qstash_message_id")
  sentAt               DateTime?       @map("sent_at")
  scheduledFor         DateTime?       @map("scheduled_for")
  createdAt            DateTime        @default(now()) @map("created_at")
  // ─── Guard audit fields (src/lib/automation-guard.ts) ──────────────────
  // status uses 'skipped_wrong_status' | 'skipped_wrong_stage' |
  // 'skipped_missing_prerequisite' | 'skipped_duplicate' | 'skipped_cancelled' |
  // 'skipped_ineligible' for guard rejections. These fields capture WHY
  // and what state the guard evaluated against, so the run history is
  // queryable without re-deriving from logs.
  skipReason           String?         @map("skip_reason")
  evaluatedStage       String?         @map("evaluated_stage")
  evaluatedStatus      String?         @map("evaluated_status")
  expectedStage        String?         @map("expected_stage")
  // 'immediate' | 'delayed_callback' | 'chained' | 'manual_rerun' | 'cron' |
  // 'public_trigger' | 'debug'. Identifies which entry point produced this
  // execution; lets us trace skipped sends by source.
  executionMode        String?         @map("execution_mode")
  // User id when the execution was produced by a manual_rerun or debug path.
  // Null for automatic paths.
  triggeredByUserId    String?         @map("triggered_by_user_id")
  // ─── Pipeline Transitions v2 ──────────────────────────────────────────
  // Pins a stage_entered execution to one specific StageEntry. Null for
  // raw-event executions (flow_completed, meeting_*, etc.) which key off
  // sessionId alone.
  //
  // Idempotency: the unique constraint below treats (stepId, sessionId,
  // channel, stageEntryId) as the key. Postgres treats NULL as distinct, so
  // raw-event execs (stageEntryId IS NULL) no longer get DB-level dedup —
  // the automation guard's pre-insert lookup is the source of truth for
  // those (it already runs and was the de-facto dedup gate even before V2).
  // For stage_entered execs, every re-entry mints a fresh StageEntry, so a
  // candidate looping back into a stage triggers the automation again.
  stageEntryId         String?         @map("stage_entry_id")
  stageEntry           StageEntry?     @relation(fields: [stageEntryId], references: [id], onDelete: SetNull)
  // ─── SendGrid delivery telemetry (src/app/api/webhooks/sendgrid) ───────
  // Reflects the most-progressed SendGrid Event Webhook event for this
  // execution's email send. Updated async after the row reaches status='sent'.
  // Values (priority low → high):
  //   processed < deferred < delivered < blocked < bounce < dropped
  // Webhook handler never downgrades a terminal failure back to processed.
  // SMS executions never populate this — it's email-only.
  deliveryStatus       String?         @map("delivery_status")
  deliveryStatusAt     DateTime?       @map("delivery_status_at")
  deliveryErrorMessage String?         @map("delivery_error_message")
  // sg_message_id is SendGrid's canonical id format (different from the
  // x-message-id header we capture at send time on providerMessageId — the
  // webhook events surface the longer "<msgid>.filter…" form). Kept separate
  // so both can be used for SendGrid Activity API lookups.
  sendgridMessageId    String?         @map("sendgrid_message_id")
  // sg_event_id is SendGrid's per-event id, used for de-dup on webhook
  // retries (the same delivered event may arrive multiple times).
  sendgridEventId      String?         @map("sendgrid_event_id")
  // Raw event payload from SendGrid, for admin debugging. Trimmed on write.
  deliveryRaw          Json?           @map("delivery_raw")
  // Timestamp of the bounce-retry attempt: when SendGrid reports an
  // HM08-like per-recipient block on a workspace-custom sender, we resend
  // the same execution once via the platform default sender (noreply@…).
  // Set once on retry; presence guarantees we never retry the same exec
  // twice (avoids loops if the platform sender is also blocked).
  bounceRetriedAt      DateTime?       @map("bounce_retried_at")
  // Captured rendered email content at send time. Lets the bounce-retry
  // path resend the exact same subject + body without re-walking the
  // variable-building chain (meeting/scheduling links, template tokens,
  // workspace branding). Also serves as a "what did we actually send"
  // audit if a recruiter asks why a delivery failed. Null for SMS rows.
  renderedSubject      String?         @map("rendered_subject")
  renderedHtml         String?         @map("rendered_html") @db.Text
  renderedText         String?         @map("rendered_text") @db.Text

  @@unique([stepId, sessionId, channel, stageEntryId])
  @@index([sessionId, status])
  @@index([stageEntryId])
  @@index([sendgridMessageId])
  @@map("automation_executions")
}

// ============ AUTOMATION EVENT LOG ============
//
// One row per business event that *could* dispatch automations. The
// `(workspaceId, eventKey)` unique constraint is the DB-enforced idempotency
// boundary: every emitter (lifecycle middleware, webhooks, cron, public
// endpoints, manual reruns) routes through `src/lib/automation-emit.ts`,
// which writes here first. Two emitters firing the same business event in
// the same millisecond → exactly one INSERT wins, the other returns a
// duplicate-key error and the wrapper short-circuits the dispatch.
//
// The pre-existing AutomationExecution dedup (stepId/sessionId/channel +
// guard) only catches races AFTER they've both reached the guard. This
// table catches them at the door — independent of step/channel/stage, so
// even multi-step rules with chained children are protected.
//
// `eventKey` is deterministic, computed by the emitter from the event
// payload. Conventions (must contain NO nullable identifiers — the
// constraint relies on stable non-null components):
//   flow_completed:{sessionId}
//   flow_passed:{sessionId}
//   recording_ready:capture:{captureResponseId}
//   recording_ready:meet:{interviewMeetingId}
//   recording_ready:flow:{sessionId}:{candidateSubmissionId}
//   training_started:{trainingEnrollmentId}
//   training_completed:{trainingEnrollmentId}
//   meeting_scheduled:{interviewMeetingId}
//   meeting_rescheduled:{interviewMeetingId}:{newScheduledStartIso}
//   meeting_started:{interviewMeetingId}
//   meeting_ended:{interviewMeetingId}
//   meeting_no_show:{interviewMeetingId}
//   transcript_ready:meet:{interviewMeetingId}
//   stage_entered:{stageEntryId}
//   background_check:{backgroundCheckId}:{outcome}
//
// `source` distinguishes the emitter for telemetry — lifecycle | webhook |
// cron | public_endpoint | manual | internal. Reconciler-driven re-fires
// don't write new event rows; they reuse the existing one via
// `redispatchAcceptedEvent`.

model AutomationEvent {
  id            String    @id @default(uuid())
  workspaceId   String    @map("workspace_id")
  sessionId     String?   @map("session_id")
  triggerType   String    @map("trigger_type")
  eventKey      String    @map("event_key")
  source        String
  payload       Json?
  acceptedAt    DateTime  @default(now()) @map("accepted_at")
  // Set when the wrapper's dispatch callback completes without throwing.
  // Null means "accepted but never finished dispatching" — these are the
  // rows the reconciler re-fires. Updated transactionally after dispatch.
  dispatchedAt  DateTime? @map("dispatched_at")
  // Captured if the dispatch callback throws. Reconciler uses this to skip
  // hopeless events instead of retrying forever (anything older than the
  // recovery window with dispatchError set is left alone after one retry).
  dispatchError String?   @map("dispatch_error")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, eventKey])
  @@index([sessionId, triggerType])
  @@index([acceptedAt])
  @@index([dispatchedAt])
  @@map("automation_events")
}

// ============ SCHEDULING ============

model SchedulingConfig {
  id                  String            @id @default(uuid())
  workspaceId         String            @map("workspace_id")
  workspace           Workspace         @relation(fields: [workspaceId], references: [id])
  createdById         String            @map("created_by_id")
  name                String
  provider            String            @default("calendly")
  schedulingUrl       String            @map("scheduling_url")
  // When true, the candidate redirect lands on the in-app HireFunnel booking
  // page (slot picker backed by Google FreeBusy). When false, the candidate
  // is 302'd to the pasted external URL (Calendly/Cal.com/etc.). Per-config
  // so a workspace can run both side-by-side.
  useBuiltInScheduler Boolean           @default(false) @map("use_built_in_scheduler")
  // Validated via parseBookingRules (src/lib/scheduling/booking-rules.ts).
  // Shape: { durationMinutes, bufferBeforeMinutes, bufferAfterMinutes,
  // minNoticeHours, maxDaysOut, slotIntervalMinutes, workingHours }.
  bookingRules        Json?             @map("booking_rules")
  // Optional override of GoogleIntegration.calendarId for FreeBusy/insert.
  // Defaults (null) to the integration's calendar.
  calendarId          String?           @map("calendar_id")
  isDefault           Boolean           @default(false) @map("is_default")
  isActive            Boolean           @default(true) @map("is_active")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  automationRules     AutomationRule[]
  automationSteps     AutomationStep[]  @relation("StepSchedulingConfig")
  events              SchedulingEvent[]
  hiringProcesses     HiringProcess[]

  @@map("scheduling_configs")
}

model SchedulingEvent {
  id                 String            @id @default(uuid())
  sessionId          String            @map("session_id")
  session            Session           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  schedulingConfigId String?           @map("scheduling_config_id")
  schedulingConfig   SchedulingConfig? @relation(fields: [schedulingConfigId], references: [id])
  eventType          String            @map("event_type")
  eventAt            DateTime          @default(now()) @map("event_at")
  metadata           Json?
  createdAt          DateTime          @default(now()) @map("created_at")

  @@map("scheduling_events")
}

// ============ CERTN BACKGROUND CHECKS ============
// Per-workspace credentials + config for the CertnCentric API. The API key
// and webhook secret are stored encrypted (AES-256-GCM via lib/crypto.ts).
// Each customer creates their own API key in the Certn Client Portal and
// pastes it into HiringFlow; we never go through OAuth (Certn doesn't expose
// it). Region is mandatory because Certn is data-domiciled — wrong region =
// 401/404 since the key is region-scoped.
model CertnIntegration {
  id                String    @id @default(uuid())
  workspaceId       String    @unique @map("workspace_id")
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  apiKeyEncrypted   String    @map("api_key_encrypted")
  // 'CA' (api.ca.certn.co) | 'UK' (api.uk.certn.co) | 'AU' (api.au.certn.co)
  region            String    @default("CA")
  // When true, route requests to the per-region sandbox host instead of
  // production. Sandbox: api.sandbox.certn.co (CA), api-uk.sandbox.certn.co
  // (UK), api-au.sandbox.certn.co (AU). Sandbox accounts and production
  // accounts have separate API keys — they're not interchangeable.
  useSandbox        Boolean   @default(false) @map("use_sandbox")
  // HMAC-SHA256 signing secret pasted in by the customer after they register
  // the HiringFlow webhook URL in the Certn portal. Encrypted.
  webhookSecret     String?   @map("webhook_secret")
  // Default check_types_with_arguments map applied when ordering a case.
  // Recruiters can override per candidate. Shape:
  //   { "IDENTITY_VERIFICATION_1": {}, "CRIMINAL_RECORD_REPORT_1": { ... } }
  defaultCheckTypes Json?     @map("default_check_types")
  // Apply expiry on Certn-side invites so abandoned applicants surface as
  // APPLICANT_EXPIRED instead of sitting indefinitely.
  inviteExpiryDays  Int       @default(7) @map("invite_expiry_days")
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  backgroundChecks BackgroundCheck[]

  @@map("certn_integrations")
}

// One row per Certn Case ordered for a Session. Status mirrors Certn's case
// lifecycle verbatim (CASE_ORDERED → APPLICANT_INVITED → ... → COMPLETE) so
// the UI can map directly to friendly badges. overallScore is set when
// Certn closes all checks; the (CLEAR | NOT_APPLICABLE) → passed,
// REJECT → failed, REVIEW/RESTRICTED → needs_review mapping decides which
// downstream automation trigger fires.
model BackgroundCheck {
  id            String           @id @default(uuid())
  workspaceId   String           @map("workspace_id")
  workspace     Workspace        @relation(fields: [workspaceId], references: [id])
  sessionId     String           @map("session_id")
  session       Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  integrationId String           @map("integration_id")
  integration   CertnIntegration @relation(fields: [integrationId], references: [id])
  // Certn case UUID — globally unique within the region.
  certnCaseId   String           @unique @map("certn_case_id")
  // Returned when ordered with return_invite_link=true. Surfaced via the
  // {{certn_link}} merge token in automation step bodies.
  inviteLink    String?          @map("invite_link")
  // Mirror of Certn case.overall_status. Defaults to CASE_ORDERED until the
  // first webhook / poll updates it.
  status        String           @default("CASE_ORDERED")
  // Mirror of Certn case.overall_score. Null until all checks close.
  overallScore  String?          @map("overall_score")
  // Snapshot of the check_types_with_arguments map sent to Certn at order
  // time. Persisted so we can re-fetch / reconcile without consulting the
  // workspace defaults again.
  checkTypes    Json             @map("check_types")
  // Most recent Certn webhook event_id processed for this case. Used to
  // dedupe in concert with ProcessedCertnEvent.
  lastEventId   String?          @map("last_event_id")
  lastSyncedAt  DateTime?        @map("last_synced_at")
  // User who clicked "Order check" on the candidate page (null for
  // automation-ordered checks).
  orderedById   String?          @map("ordered_by_id")
  completedAt   DateTime?        @map("completed_at")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  @@index([workspaceId, status])
  @@index([sessionId])
  @@map("background_checks")
}

// Idempotency ledger for Certn webhook deliveries. Mirrors the
// ProcessedWorkspaceEvent pattern used for Google Meet — Certn retries with
// exponential backoff for ~2h, so the same event_id can arrive multiple times.
model ProcessedCertnEvent {
  id           String   @id @default(uuid())
  workspaceId  String   @map("workspace_id")
  certnEventId String   @map("certn_event_id")
  eventType    String   @map("event_type")
  caseId       String   @map("case_id")
  processedAt  DateTime @default(now()) @map("processed_at")

  @@unique([workspaceId, certnEventId])
  @@index([processedAt])
  @@map("processed_certn_events")
}

// ============ CAPTURE RESPONSES (generic Capture Engine) ============
// One CaptureResponse per (session, step, captureOrdinal). Generic across all
// modes — audio / video / audio_video / text / upload / future ai_call. The
// legacy CandidateSubmission table is preserved untouched; the two systems
// coexist and the recruiter UI reads both. New capture flow steps
// (stepType='capture') write here.
//
// Media is stored privately in S3 under a deterministic, tenant-scoped key:
//   captures/{workspaceId}/{sessionId}/{stepId}/{captureResponseId}.{ext}
// Playback is served via short-lived signed URLs through
// GET /api/captures/[id]/playback — never via public bucket URLs.
//
// Status lifecycle:
//   draft → uploading → uploaded → processing → processed
//   failed is terminal and may be entered from uploading or processing.
//   Phase 1 without transcription/AI: uploaded transitions directly to
//   processed in capture-response.service.finalize.
//
// TODO(orphan-cleanup): a future cron should sweep:
//   1) draft/uploading rows older than 24h (candidate abandoned upload mid-flow)
//   2) failed rows older than 30d (audit window long enough for support)
//   3) S3 objects under captures/* whose key has no matching DB row (presign
//      issued, candidate uploaded, finalize never ran — leaks bytes only)
// Not in Phase 1 scope; see src/lib/capture/capture-response.service.ts for
// the corresponding service-level notes.
model CaptureResponse {
  id              String    @id @default(uuid())
  workspaceId     String    @map("workspace_id")
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  // FK to flows table — matches the existing convention used by FlowStep,
  // Session, and AutomationRule (all of which carry both `flow_id` column
  // and a Flow relation). Cascading the delete keeps capture rows in sync
  // when a flow is removed, same as how FlowStep behaves.
  flowId          String    @map("flow_id")
  flow            Flow      @relation(fields: [flowId], references: [id], onDelete: Cascade)
  stepId          String    @map("step_id")
  step            FlowStep  @relation(fields: [stepId], references: [id], onDelete: Cascade)
  sessionId       String    @map("session_id")
  session         Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  // 'text' | 'audio' | 'video' | 'audio_video' | 'upload' | 'ai_call'
  // ai_call is reserved for future use; the dashboard review UI is designed
  // so existing/future AI call records can surface here without a new table.
  mode            String
  prompt          String?
  // Storage abstraction. 's3' for new uploads in Phase 1. Future values:
  // 'vercel_blob' (legacy), 'external_url' (ai_call provider).
  storageProvider String?   @map("storage_provider")
  // Tenant-scoped, server-generated only. NEVER from client input. See
  // buildCaptureStorageKey() in capture-storage.service.ts.
  storageKey      String?   @map("storage_key")
  mimeType        String?   @map("mime_type")
  fileSizeBytes   Int?      @map("file_size_bytes")
  durationSec     Float?    @map("duration_sec")
  transcript      String?
  aiSummary       String?   @map("ai_summary")
  aiScore         Float?    @map("ai_score")
  aiMetadata      Json?     @map("ai_metadata")
  // Status lifecycle (see model header).
  status          String    @default("draft")
  errorMessage    String?   @map("error_message")
  // Retake bookkeeping. captureOrdinal increments per (session, step) so we
  // can keep prior takes without violating a single-row unique constraint
  // while still being able to identify the "active" take (status='processed'
  // with the highest ordinal — surfaced by capture-response.service).
  captureOrdinal  Int       @default(1) @map("capture_ordinal")
  // Public share token. When set, anyone with the URL can play this recording
  // via the unauthenticated /api/public/captures/[token] route. Minted on
  // demand by the recruiter "Share" button and revoked by clicking Unshare.
  // Indexed for the public lookup. Per-row toggle so a leaked link can be
  // killed without touching other captures.
  shareToken      String?   @unique @map("share_token")
  shareCreatedAt  DateTime? @map("share_created_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@unique([sessionId, stepId, captureOrdinal])
  // Tenant-scoped read paths used by the recruiter list endpoint.
  @@index([workspaceId, sessionId])
  @@index([workspaceId, status])
  // Recent-activity feed within a session, ordered newest-first.
  @@index([workspaceId, sessionId, createdAt(sort: Desc)])
  // Single-column indexes for FK joins / cascade traversals. Postgres uses
  // these for cascade delete planning and for the cleanup cron's
  // per-{flow,step,session} scans.
  @@index([flowId])
  @@index([stepId])
  @@index([sessionId])
  @@map("capture_responses")
}
