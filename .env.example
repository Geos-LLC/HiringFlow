# Database (Supabase)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# Initial Admin (for seeding)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme123"

# LogHub (server monitoring, legacy)
LOGHUB_URL="https://geosloghub-production.up.railway.app"
LOGHUB_SOURCE="railway"
LOGHUB_KEY="your-loghub-ingest-key"

# FixPrompt (browser error reporting → Grafana / LogHub)
# Get a k_… key from https://fixprompt-dashboard.vercel.app/onboarding/new
# Leave unset in dev to disable.
NEXT_PUBLIC_FIXPROMPT_KEY=""

# OpenAI
OPENAI_API_KEY="your-openai-api-key"

# Stripe Billing
STRIPE_SECRET_KEY="sk_test_..."
